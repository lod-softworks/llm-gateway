{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "Database": {
    "Provider": "Sqlite"
  },
  "ConnectionStrings": {
    "Gateway": "Data Source=App_Data/Llm.Gateway.db"
  },
  "OpenAIChatCompletions": {
    "Providers": [
      {
        "Name": "LMStudio",
        "BaseUrl": "http://localhost:1234",
        "AcceptAnyModel": true,
        "CopyMaxCompletionTokensToMaxTokens": true
      }
    ]
  }
}
